---
import { FaGithub } from 'react-icons/fa';

const projects = [
  {
    title: "Odometer Reading Detection",
    tech: "Python, PyTorch, OpenCV, Git",
    description: "Built a YOLOv5-nano + OCR pipeline to read odometers; achieved 90.75% accuracy on 3,460 test images after training on 6,000 labeled images; improved robustness to glare/blur via targeted augmentations and post-processing.",
    link: "https://github.com/abhijeetdhupia"
  }
];
---

<section id="projects" class="pb-12">
  <h3 class="text-[11px] font-black uppercase tracking-[0.2em] text-cyan-500/70 border-b border-zinc-900 pb-3 mb-10">Featured Projects</h3>
  <div class="space-y-8">
    {projects.map((project) => (
      <div class="group p-6 md:p-8 bg-zinc-900/40 rounded-3xl border border-zinc-800 hover:border-cyan-500/30 hover:shadow-2xl hover:shadow-cyan-500/5 transition-all duration-300">
        <div class="flex items-center justify-between mb-4">
          <h4 class="text-xl font-bold text-zinc-100 font-['Merriweather',_serif]">{project.title}</h4>
          <a href={project.link} target="_blank" rel="noopener noreferrer" class="p-2.5 bg-zinc-950 rounded-xl text-zinc-500 hover:text-cyan-400 border border-zinc-800 transition-colors shadow-sm">
            <FaGithub size={20} />
          </a>
        </div>
        <p class="text-xs font-bold uppercase tracking-widest text-cyan-400 mb-4">{project.tech}</p>
        <p class="text-zinc-400 leading-relaxed mb-6 font-medium">
          {project.description}
        </p>
      </div>
    ))}
  </div>
</section>
