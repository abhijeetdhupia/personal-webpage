---
const skillGroups = [
  {
    category: "Languages",
    skills: ["Python", "SQL", "C++", "Bash", "LaTeX"]
  },
  {
    category: "ML / Deep Learning",
    skills: ["PyTorch", "TensorFlow", "OpenCV", "FastAPI", "Flyte"]
  },
  {
    category: "Infrastructure / Tools",
    skills: ["Docker", "AWS", "GCP", "Git", "Qdrant"]
  }
];
---

<section id="skills" class="py-20">
  <h3 class="text-[11px] font-black uppercase tracking-[0.2em] text-cyan-500/70 border-b border-zinc-900 pb-3 mb-12">Technical Skills</h3>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
    {skillGroups.map((group) => (
      <div class="space-y-6">
        <h4 class="text-[11px] font-black uppercase tracking-[0.2em] text-zinc-500 border-b border-zinc-900 pb-3">{group.category}</h4>
        <div class="flex flex-wrap gap-2">
          {group.skills.map((skill) => (
            <span class="px-3.5 py-1.5 bg-zinc-900 text-zinc-300 text-xs font-bold rounded-full border border-zinc-800 hover:border-cyan-500/50 hover:text-cyan-400 transition-all cursor-default">
              {skill}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
