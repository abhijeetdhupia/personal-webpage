---
const skillGroups = [
  {
    category: "Languages",
    skills: ["Python", "SQL", "C++", "Bash", "LaTeX"]
  },
  {
    category: "ML / Deep Learning",
    skills: ["PyTorch", "TensorFlow", "OpenCV", "FastAPI", "Flyte"]
  },
  {
    category: "Infrastructure / Tools",
    skills: ["Docker", "AWS", "GCP", "Git", "Qdrant"]
  }
];
---

<section id="skills" class="py-20 border-t border-gray-100">
  <h3 class="text-3xl font-bold text-gray-900 mb-12">Technical Skills</h3>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
    {skillGroups.map((group) => (
      <div class="space-y-6">
        <h4 class="text-sm font-bold uppercase tracking-wider text-gray-400 border-b border-gray-100 pb-2">{group.category}</h4>
        <div class="flex flex-wrap gap-2">
          {group.skills.map((skill) => (
            <span class="px-3 py-1 bg-blue-50 text-blue-700 text-sm font-semibold rounded-full border border-blue-100">
              {skill}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
