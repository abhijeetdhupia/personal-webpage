---
const publications = [
  {
    authors: "A. Dhupia, J. R. Harish Kumar, J. Andrade, and K. V. Rajagopal",
    title: "Automatic segmentation of lumen intima layer in longitudinal mode ultrasound images",
    venue: "2020 42nd Annual International Conference of the IEEE Engineering in Medicine Biology Society (EMBC)",
    year: "2020",
    pages: "2125–2128",
    link: "https://ieeexplore.ieee.org/abstract/document/9175831/"
  }
];
---

<section id="publications" class="pt-8">
  <h3 class="text-[11px] font-black uppercase tracking-[0.2em] text-cyan-500/70 border-b border-zinc-900 pb-3 mb-10">Selected Publications</h3>
  <div class="space-y-8">
    {publications.map((pub) => (
      <div class="p-6 md:p-8 bg-zinc-900/30 border border-zinc-800 rounded-3xl shadow-sm hover:shadow-2xl hover:shadow-cyan-500/5 transition-all duration-300">
        <p class="text-xs font-bold text-cyan-400 uppercase tracking-widest mb-3">{pub.year}</p>
        <h4 class="text-2xl font-bold text-zinc-100 mb-4 font-['Merriweather',_serif] leading-tight">{pub.title}</h4>
        <p class="text-zinc-400 font-medium mb-6 text-sm">{pub.authors}</p>
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-6 border-t border-zinc-800/50 pt-6">
          <p class="text-xs text-zinc-500 font-bold uppercase tracking-wide">{pub.venue}</p>
          <a href={pub.link} target="_blank" rel="noopener noreferrer" class="text-sm font-black text-cyan-400 hover:text-cyan-300 flex items-center gap-2 group/link uppercase tracking-wider">
            Read Publication
            <span class="group-hover/link:translate-x-1 transition-transform">→</span>
          </a>
        </div>
      </div>
    ))}
  </div>
</section>
