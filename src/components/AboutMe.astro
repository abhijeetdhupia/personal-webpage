---
import { Image } from 'astro:assets';
import profileImage from '../assets/profile.jpg';
import { Mail, GraduationCap, FileText } from 'lucide-react';
import { FaLinkedin, FaGithub } from 'react-icons/fa';
import { SiGooglescholar } from 'react-icons/si';
---

<section class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-20">
  <!-- Left Sidebar -->
  <div class="flex flex-col items-center md:items-start text-center md:text-left space-y-6">
    <div class="w-48 h-48 md:w-56 md:h-56 rounded-2xl overflow-hidden shadow-xl ring-4 ring-gray-50 bg-gray-100">
      <Image 
        src={profileImage} 
        alt="Abhijeet Dhupia" 
        width={400} 
        height={400} 
        class="w-full h-full object-cover"
        loading="eager"
      />
    </div>
    
    <div class="space-y-2">
      <h2 class="text-3xl font-bold tracking-tight text-gray-900">Abhijeet Dhupia</h2>
      <p class="text-lg font-medium text-gray-600">Senior Machine Learning Engineer @ Bazaarvoice</p>
      <p class="text-blue-600 font-medium">Bangalore, India</p>
    </div>

    <div class="flex flex-wrap justify-center md:justify-start gap-4 pt-2">
      <a href="mailto:hello@abhijeetdhupia.com" class="p-2 bg-gray-50 rounded-lg hover:bg-blue-50 hover:text-blue-600 transition-all text-gray-600" title="Email">
        <Mail size={24} />
      </a>
      <a href="https://linkedin.com/in/abhijeetdhupia" target="_blank" rel="noopener noreferrer" class="p-2 bg-gray-50 rounded-lg hover:bg-blue-50 hover:text-blue-600 transition-all text-gray-600" title="LinkedIn">
        <FaLinkedin size={24} />
      </a>
      <a href="https://github.com/abhijeetdhupia" target="_blank" rel="noopener noreferrer" class="p-2 bg-gray-50 rounded-lg hover:bg-blue-50 hover:text-blue-600 transition-all text-gray-600" title="GitHub">
        <FaGithub size={24} />
      </a>
      <a href="https://scholar.google.com/citations?user=KC6C5BkAAAAJ&hl=en&oi=ao" target="_blank" rel="noopener noreferrer" class="p-2 bg-gray-50 rounded-lg hover:bg-blue-50 hover:text-blue-600 transition-all text-gray-600" title="Google Scholar">
        <SiGooglescholar size={24} />
      </a>
      <a href="/personal-webpage/Abhijeet_Dhupia_CV.pdf" target="_blank" rel="noopener noreferrer" class="p-2 bg-gray-50 rounded-lg hover:bg-blue-50 hover:text-blue-600 transition-all text-gray-600" title="CV">
        <FileText size={24} />
      </a>
    </div>
  </div>

  <!-- Main Content Area -->
  <div class="md:col-span-2 space-y-10">
    <div>
      <h3 class="text-4xl font-extrabold text-gray-900 mb-6">About Me</h3>
      <div class="prose prose-lg text-gray-600 leading-relaxed space-y-4">
        <p>
          I am a Senior Machine Learning Engineer at Bazaarvoice, Bangalore, where I specialize in building and scaling production ML systems. Currently, I'm focused on vector search migrations, LLM-based RAG assistants, and high-throughput computer vision pipelines.
        </p>
        <p>
          Prior to Bazaarvoice, I developed YOLO-based detection pipelines at Sentryc and delivered end-to-end ML systems across CV/NLP at Big Vision. My journey began as a Research Assistant at the Indian Institute of Science (IISc), where I worked on medical imaging models for endoscopy and OCT pathology.
        </p>
        <p>
          Apart from work, I relish cooking, snapshotting, and watching Formula 1.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-10 pt-6">
      <div class="space-y-4">
        <h4 class="text-xl font-bold text-gray-900">Interests</h4>
        <ul class="space-y-2 text-gray-600">
          <li class="flex items-center gap-3">
            <span class="w-1.5 h-1.5 bg-blue-600 rounded-full"></span>
            Biomedical Imaging
          </li>
          <li class="flex items-center gap-3">
            <span class="w-1.5 h-1.5 bg-blue-600 rounded-full"></span>
            Computer Vision
          </li>
          <li class="flex items-center gap-3">
            <span class="w-1.5 h-1.5 bg-blue-600 rounded-full"></span>
            Signal Processing
          </li>
          <li class="flex items-center gap-3">
            <span class="w-1.5 h-1.5 bg-blue-600 rounded-full"></span>
            LLMs & RAG Systems
          </li>
        </ul>
      </div>

      <div class="space-y-4">
        <h4 class="text-xl font-bold text-gray-900">Education</h4>
        <div class="flex gap-4">
          <div class="mt-1 p-2 bg-blue-50 text-blue-600 rounded-lg shrink-0 h-fit">
            <GraduationCap size={20} />
          </div>
          <div class="space-y-1">
            <p class="font-semibold text-gray-900 leading-tight">B.Tech in Electrical and Electronics</p>
            <p class="text-sm text-gray-600 font-medium italic">Minor in Data Science</p>
            <p class="text-sm text-gray-600 font-medium">2015 - 2019</p>
            <p class="text-sm text-gray-500 italic">Manipal Institute of Technology</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
