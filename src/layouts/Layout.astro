---
import '../styles/global.css'
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Merriweather:ital,wght@0,400;0,700;0,900;1,400;1,700&display=swap" rel="stylesheet">
	</head>
	<body class="bg-zinc-950 text-zinc-300 font-['Inter',_sans-serif] selection:bg-cyan-500/30 selection:text-cyan-100 bg-[radial-gradient(#18181b_1px,transparent_1px)] [background-size:24px_24px]">
		<header class="max-w-6xl mx-auto px-4 md:px-6 py-4 md:py-8 flex flex-col md:flex-row md:items-center justify-between border-b border-zinc-900 mb-8 md:mb-12 sticky top-0 bg-zinc-950/90 backdrop-blur-md z-50 gap-y-4 md:gap-x-4">
			<div class="flex flex-col md:flex-row md:items-center gap-2 md:gap-4">
				<a href="#home" class="text-xl md:text-2xl font-bold tracking-tight text-center md:text-left font-['Merriweather',_serif] text-zinc-100">Abhijeet Dhupia</a>
				<span class="hidden md:block text-[9px] font-mono text-cyan-500/50 bg-cyan-500/5 px-2 py-0.5 rounded-full border border-cyan-500/10 uppercase tracking-widest leading-none">V3.4-STABLE</span>
			</div>
			<nav>
				<ul class="flex flex-wrap justify-center md:justify-end gap-x-4 gap-y-1.5 md:gap-x-8 text-[11px] sm:text-xs md:text-sm font-medium text-zinc-400 uppercase tracking-wide">
					<li><a href="#home" class="hover:text-cyan-400 transition-colors py-1 block">Home</a></li>
					<li><a href="#experience" class="hover:text-cyan-400 transition-colors py-1 block">Experience</a></li>
					<li><a href="#projects" class="hover:text-cyan-400 transition-colors py-1 block">Projects</a></li>
					<li><a href="#publications" class="hover:text-cyan-400 transition-colors py-1 block">Publications</a></li>
					<li><a href="#skills" class="hover:text-cyan-400 transition-colors py-1 block">Skills</a></li>
					<li><a href="mailto:hello@abhijeetdhupia.com" class="hover:text-cyan-400 transition-colors py-1 block">Contact</a></li>
				</ul>
			</nav>
		</header>
		<main id="home" class="max-w-6xl mx-auto px-4 md:px-6 pb-24">
			<slot />
		</main>
		<footer class="max-w-6xl mx-auto px-4 md:px-6 py-12 border-t border-zinc-900 text-center text-sm text-zinc-500">
			&copy; {new Date().getFullYear()} Abhijeet Dhupia. Built with Astro & Tailwind.
		</footer>
	</body>
</html>

<style is:global>
	html {
		scroll-behavior: smooth;
	}
</style>
